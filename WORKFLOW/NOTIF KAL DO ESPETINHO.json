        "functionCode": "const order = $json.body?.message_data || {};\nconst phone = `55${$json.body?.phone_number}`;\nconst items = Array.isArray(order.items) ? order.items.map(i => `• ${i.quantity}x ${i.name} - R$ ${(i.price * i.quantity).toFixed(2)}`).join('\\n') : 'Nenhum item';\nconst entrega = order.delivery_type === 'delivery' ? `Endereço: ${order.address}\\nTaxa de Entrega: R$ ${order.delivery_fee}` : 'Retirada no Local';\nconst msg = `*🎉 Novo Pedido Recebido - C&R Sushi 🎉*\\n\\n*Número do Pedido:* ${order.order_number}\\n*Cliente:* ${order.customer_name}\\n\\n*Itens:*\\n${items}\\n\\n*Entrega:*\\n${entrega}\\n\\n*Pagamento:* ${order.payment_method}\\n*Total:* R$ ${order.total}`;\nreturn [{json:{phoneNumber:phone,message:msg}}];"
      },
